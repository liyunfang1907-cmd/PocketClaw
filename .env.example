# ============================================
# PocketClaw 环境变量配置
# 复制此文件为 .env 并填入实际值:
#   copy .env.example .env    (Windows)
#   cp .env.example .env      (macOS/Linux)
#
# 或者直接运行配置向导: scripts/setup-env.bat (Windows)
#                       bash scripts/setup-env.sh (macOS/Linux)
# ============================================

# ---------- Docker Compose 项目名 ----------
COMPOSE_PROJECT_NAME=pocketclaw

# ---------- AI 模型提供商 ----------
# 支持: zhipu, deepseek, moonshot, qwen, yi, siliconflow
PROVIDER_NAME=zhipu

# ---------- 默认模型 ----------
# 智谱: glm-4.7-flash | DeepSeek: deepseek-chat | Moonshot: moonshot-v1-auto
# 通义千问: qwen-turbo-latest | Yi: yi-lightning | 硅基流动: deepseek-ai/DeepSeek-V3
OPENCLAW_MODEL=glm-4.7-flash

# ---------- API Key ----------
# 所有厂商通用，填入你选择的厂商的 API Key
# 智谱: https://open.bigmodel.cn/usercenter/apikeys
# DeepSeek: https://platform.deepseek.com/api_keys
# Moonshot: https://platform.moonshot.cn/console/api-keys
# 通义千问: https://dashscope.console.aliyun.com/apiKey
# Yi: https://platform.lingyiwanwu.com/apikeys
# 硅基流动: https://cloud.siliconflow.cn/account/ak
OPENAI_API_KEY=

# ---------- 向后兼容 (旧版配置) ----------
# 如果你之前使用的是 ZHIPU_API_KEY，仍然有效
# ZHIPU_API_KEY=

# ---------- Gateway 认证密码 ----------
# 用于保护 WebSocket 连接，默认值: pocketclaw
GATEWAY_AUTH_PASSWORD=pocketclaw

