# ============================================
# PocketClaw 聊天频道配置示例
# 将需要的变量复制到 .env 文件中即可启用
# 或运行 scripts/setup-channels.sh (macOS/Linux)
#       scripts\setup-channels.bat (Windows)
# ============================================

# ── Telegram（最简单，推荐首选）──
# 获取方法: Telegram 搜索 @BotFather → /newbot
# TELEGRAM_BOT_TOKEN=123456:ABCdefGhIjKlMnOpQrStUvWxYz

# ── Discord ──
# 获取方法: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your-discord-bot-token

# ── Slack（需要两个 Token）──
# 获取方法: https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token

# ── WhatsApp ──
# 首次启动后查看日志扫码: docker compose logs -f pocketclaw
# WHATSAPP_ALLOW_FROM=+8613800138000,+8613900139000

# ── Signal ──
# 需要 signal-cli，详见: https://docs.openclaw.ai/channels/signal
# SIGNAL_PHONE_NUMBER=+8613800138000

# ── Google Chat ──
# 需要 Google Cloud 服务账号，详见: https://docs.openclaw.ai/channels/googlechat
# GOOGLE_CHAT_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CHAT_SPACES=spaces/XXXXXXX

# ── Microsoft Teams ──
# 需要 Azure Bot Framework，详见: https://docs.openclaw.ai/channels/msteams
# MSTEAMS_APP_ID=your-app-id
# MSTEAMS_APP_PASSWORD=your-app-password

# ── Matrix ──
# 可使用 matrix.org 或自建服务器
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_USER_ID=@mybot:matrix.org
# MATRIX_ACCESS_TOKEN=your-access-token

# ── BlueBubbles (iMessage) ──
# 需要 macOS 上运行 BlueBubbles Server
# 详见: https://docs.openclaw.ai/channels/bluebubbles
# BLUEBUBBLES_SERVER_URL=http://192.168.1.100:1234
# BLUEBUBBLES_PASSWORD=your-server-password

# ── Zalo ──
# 需要 Zalo Official Account
# 详见: https://developers.zalo.me/
# ZALO_OA_ACCESS_TOKEN=your-oa-access-token
